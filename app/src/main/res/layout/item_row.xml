<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".Item">

    <ImageView
        android:id="@+id/itemImageView"
        android:layout_marginLeft="5dp"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_vertical"
        android:src="@mipmap/ic_launcher" />

    <LinearLayout
        android:id="@+id/itemLinearLayout"
        android:layout_width="181dp"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemCategoryTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="Category"
            android:textColor="@color/SimplyStockBlue"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/itemDescriptionTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="Description"
            android:textColor="@color/black"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/itemAvaliability"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="Avaliability"
            android:textSize="20sp" />

    </LinearLayout>

    <Button
        android:id="@+id/itemAddBtn"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_vertical"
        android:backgroundTint="#0770B3"
        android:text="+"
        android:textColor="@color/white"
        android:textSize="50sp"
        app:cornerRadius="0dp" />
</LinearLayout>