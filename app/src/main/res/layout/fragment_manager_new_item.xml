<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D7D5D5"
    android:backgroundTint="#FFE9B7"
    tools:context=".ManagerNewItemFragment">


    <TextView
        android:id="@+id/textView14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="New Item"
        android:textAlignment="center"
        android:textColor="#0770B3"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/niFrameLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/niDescirptionEditText"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#0770B3"
        android:ems="10"
        android:hint="Description"
        android:inputType="text"
        android:textColor="@color/black"
        android:textColorHint="#0770B3"
        app:layout_constraintBottom_toTopOf="@+id/niURLEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/niURLEditText"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#0770B3"
        android:ems="10"
        android:hint="URL"
        android:inputType="text"
        android:textColor="@color/black"
        android:textColorHint="#0770B3"
        app:layout_constraintBottom_toTopOf="@+id/niCategoryEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/niCategoryEditText"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#0770B3"
        android:ems="10"
        android:hint="Category"
        android:inputType="text"
        android:textColor="@color/black"
        android:textColorHint="#0770B3"
        app:layout_constraintBottom_toTopOf="@+id/niAvailabilityEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/niAvailabilityEditText"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#0770B3"
        android:ems="10"
        android:hint="Amount added"
        android:inputType="number"
        android:textColor="@color/black"
        android:textColorHint="#0770B3"
        app:layout_constraintBottom_toTopOf="@+id/niLowStockEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/niLowStockEditText"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#0770B3"
        android:ems="10"
        android:hint="Low Stock Warning"
        android:inputType="number"
        android:textColor="@color/black"
        android:textColorHint="#0770B3"
        app:layout_constraintBottom_toTopOf="@+id/niCreateNewItem"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/niCreateNewItem"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:backgroundTint="#0770B3"
        android:text="Create New Item"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="25sp"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/niFrameLayout"
        android:layout_width="270dp"
        android:layout_height="270dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/frame_layout_outline"
        android:clickable="true"
        app:layout_constraintBottom_toTopOf="@+id/niDescirptionEditText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/niImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/plus_icon" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>